{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Unknown action",
      "method": "POST",
      "path": "/",
      "body": {"action": "unknown"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "subscribe — missing fields",
      "method": "POST",
      "path": "/",
      "body": {"action": "subscribe", "endpoint": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "send_to_parent — missing id",
      "method": "POST",
      "path": "/",
      "body": {"action": "send_to_parent"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
