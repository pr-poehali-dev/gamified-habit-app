{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Unknown action returns error",
      "method": "POST",
      "path": "/",
      "body": {"action": "unknown"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Неизвестное действие."},
      "bodyMatcher": "partial"
    },
    {
      "name": "send_otp — invalid phone",
      "method": "POST",
      "path": "/",
      "body": {"action": "send_otp", "phone": "123"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Неверный формат номера телефона"},
      "bodyMatcher": "partial"
    },
    {
      "name": "check_phone — invalid phone",
      "method": "POST",
      "path": "/",
      "body": {"action": "check_phone", "phone": "123"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Неверный формат номера телефона"},
      "bodyMatcher": "partial"
    },
    {
      "name": "check_phone — unknown number",
      "method": "POST",
      "path": "/",
      "body": {"action": "check_phone", "phone": "+79999999999"},
      "expectedStatus": 200,
      "expectedBody": {"registered": false, "has_pin": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "login_pin — invalid pin",
      "method": "POST",
      "path": "/",
      "body": {"action": "login_pin", "phone": "+79999999999", "pin": "12"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "set_pin — no session",
      "method": "POST",
      "path": "/",
      "body": {"action": "set_pin", "session_token": "", "pin": "1234"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "verify_session — invalid token",
      "method": "POST",
      "path": "/",
      "body": {"action": "verify_session", "session_token": "nonexistent_token_xyz", "role": "parent"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Сессия недействительна."},
      "bodyMatcher": "partial"
    },
    {
      "name": "register_child — invalid invite code",
      "method": "POST",
      "path": "/",
      "body": {"action": "register_child", "invite_code": "INVALID999"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}